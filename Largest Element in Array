Find Largest Element in an Array
1️⃣ Brute Force (Sorting)
Idea

Sort the array and return the last element.

Code
#include <bits/stdc++.h>
using namespace std;

int largestElement(vector<int>& arr) {
    int n = arr.size();
    sort(arr.begin(), arr.end());
    return arr[n-1];
}

int main() {
    vector<int> arr = {3,7,2,9,5};
    cout << largestElement(arr);
}
Complexity

Time Complexity: O(n log n)
Space Complexity: O(1)

2️⃣ Better Approach (Linear Scan)
Idea

Traverse the array and keep track of the maximum element.

Code
#include <bits/stdc++.h>
using namespace std;

int largestElement(vector<int>& arr) {
    int largest = arr[0];

    for(int i = 1; i < arr.size(); i++) {
        if(arr[i] > largest) {
            largest = arr[i];
        }
    }

    return largest;
}

int main() {
    vector<int> arr = {3,7,2,9,5};
    cout << largestElement(arr);
}
Complexity

Time Complexity: O(n)
Space Complexity: O(1)

3️⃣ Optimal Approach (Using STL)
Idea

Use C++ STL function max_element().

Code
#include <bits/stdc++.h>
using namespace std;

int largestElement(vector<int>& arr) {
    return *max_element(arr.begin(), arr.end());
}

int main() {
    vector<int> arr = {3,7,2,9,5};
    cout << largestElement(arr);
}
Complexity

Time Complexity: O(n)
Space Complexity: O(1)
